import ee

ee.Authenticate()
ee.Initialize(
    project = 'ee-amirhosseinahrari',
    opt_url = 'https://earthengine-highvolume.googleapis.com'
)

"""# **Study Area**"""

import geemap

map = geemap.Map()
map

point = map.draw_last_feature.geometry()
point

province = (
    ee.FeatureCollection("FAO/GAUL_SIMPLIFIED_500m/2015/level1")
    .filterBounds(point)
    .geometry().simplify(1000)
)

map.addLayer(province, {}, 'province')

"""# **Image Collections**"""

flood = (
    ee.ImageCollection("JRC/CEMS_GLOFAS/FloodHazard/v2_1")
    .filterBounds(province)
    .select(['RP10_depth'],['flood'])
    .mean()
)

ndvi = (
    ee.ImageCollection("MODIS/061/MOD13A1")
    .filterDate('2020','2026')
    .select('NDVI','EVI')
    .median()
)

pr = (
    ee.ImageCollection("IDAHO_EPSCOR/TERRACLIMATE")
    .filterDate('2020','2025')
    .select('pr')
    .mean()
)


lc = (
    ee.ImageCollection("MODIS/061/MCD12Q1")
    .filterDate('2020','2025')
    .select('LC_Type1')
    .mode()
)

dem = (
    ee.Image("USGS/SRTMGL1_003")
)


dataset = ee.Image.cat([ndvi, pr, lc, dem, flood])

dataset

"""# **Image Collection to Xarray**"""

from shapely.geometry import shape
from xee import helpers
import xarray as xr

grid_params = helpers.fit_geometry(
    geometry = shape(province.getInfo()),
    grid_crs = 'EPSG:3857',
    grid_scale = (500, -500)
)

ds = xr.open_dataset(
    dataset,
    engine = 'ee',
    **grid_params
)

ds = ds.squeeze('time').drop_vars('time') * 1

ds

"""# **Image Clip**"""

!pip install rioxarray

import rioxarray

import geopandas as gpd

province_gdf = geemap.ee_to_gdf(ee.FeatureCollection(province))

province_proj = province_gdf.to_crs('EPSG:3857')

ds_clip = ds.rio.clip(province_proj.geometry, province_proj.crs)

ds_clip.flood.plot(x ='x',y = 'y', robust = True)

"""# **Risk Modelling**"""

ds_clip['flood_bin'] = (ds_clip.flood > 1).astype(int)

df = ds_clip.to_dataframe().dropna().drop(['spatial_ref','flood'], axis = 1)
df

x = df.drop('flood_bin', axis = 1)
y = df['flood_bin']

from sklearn.model_selection import train_test_split

x_train, x_test, y_train, y_test = train_test_split(x, y, test_size = 0.2,
                                                    random_state = 42)

from sklearn.ensemble import RandomForestClassifier

model = RandomForestClassifier(n_estimators = 100, random_state = 42)
model.fit(x_train, y_train)

y_pred = model.predict(x_test)

from sklearn.metrics import classification_report

print(classification_report(y_test, y_pred))

df['risk'] = model.predict_proba(x)[:,1]

dx = df.to_xarray().sortby(['y','x'])

"""# **Visualization**"""

import matplotlib.pyplot as plt

fig, ax = plt.subplots()

province_proj.plot(ax = ax, alpha = 0.5, color = 'black')
dx.risk.plot(x = 'x', y = 'y', robust = True, vmin = 0.8, ax = ax)

"""# **Risky Area**"""

x_res, y_res = dx.rio.resolution()

pixel_size = abs(x_res * y_res)

((dx.risk == 1).sum(dim = ['y','x']).item() * pixel_size) / 1e6
