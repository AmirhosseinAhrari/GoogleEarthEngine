import ee

ee.Authenticate()
ee.Initialize(
    project = 'ee-amirhosseinahrari',
    opt_url = 'https://earthengine-highvolume.googleapis.com'
)

"""# **Study Area**"""

import geemap

map = geemap.Map()
map

point = map.draw_last_feature.geometry()
point

roi  = (
    ee.FeatureCollection("USDOS/LSIB_SIMPLE/2017")
    .filterBounds(point)
    .geometry().simplify(1000)
)

map.addLayer(roi, {}, 'Iran')

"""# **ERA5 Precipitation Image Collection**"""

collection = (
    ee.ImageCollection("ECMWF/ERA5_LAND/MONTHLY_AGGR")
    .filterDate('2000','2026')
    .select(['total_precipitation_sum'],['pr'])
)

collection

"""# **to Xarray**"""

from xee import helpers
from shapely.geometry import shape
import xarray as xr

grid_params = helpers.fit_geometry(
    geometry = shape(roi.getInfo()),
    grid_crs = 'EPSG:4326',
    grid_scale = (0.11, -0.11)
)

ds = xr.open_dataset(
    collection,
    engine = 'ee',
    **grid_params
)

ds = ds.sortby('time') * 1000

"""# **Clip**"""

import geopandas as gpd

roi_gdf = geemap.ee_to_gdf(ee.FeatureCollection(roi))

!pip install rioxarray
import rioxarray

ds_clip = ds.rio.clip(roi_gdf.geometry, roi_gdf.crs)

ds_clip

"""# **Annual Precipitation**"""

pr_annual = ds_clip.resample(time = 'YS').sum('time')

import numpy as np

pr_annual_mask = pr_annual.where(pr_annual > 0, np.nan)

pr_annual_mask.pr.plot.contourf(
    x = 'x', y = 'y', robust = True, col = 'time',
    col_wrap = 7, cmap = 'turbo_r', levels = 10
)

"""# **Anomaly Mapping**"""

pr_mean = pr_annual_mask.mean('time')

pr_anomaly = pr_annual_mask - pr_mean

pr_anomaly.pr.plot.contourf(
    x = 'x', y = 'y', robust =True, cmap = 'turbo_r', levels = 10,
    col_wrap = 7, col = 'time'
)

pr_std = pr_annual_mask.std('time')

pr_std.pr.plot.contourf(
    x = 'x', y = 'y', robust = True, cmap = 'turbo_r', levels = 10
)

pr_anomaly_stan = (pr_annual_mask - pr_mean) / pr_std

import matplotlib.pyplot as plt

pr_anomaly_stan.pr.plot.contourf(
    x = 'x', y = 'y', robust =True, col = 'time', cmap = 'turbo_r', levels = 10,
    col_wrap = 7
)

plt.savefig('pr_anomaly.png', dpi = 360, bbox_inches = 'tight')

pr_annual_change = pr_annual_mask.diff('time')

pr_annual_change.pr.plot.contourf(
    x = 'x', y = 'y', robust = True, cmap = 'turbo_r', levels = 10,
    col = 'time', col_wrap = 7
)
