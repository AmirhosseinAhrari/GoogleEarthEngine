import ee

ee.Authenticate()
ee.Initialize(
    project = 'ee-amirhosseinahrari',
    opt_url = 'https://earthengine-highvolume.googleapis.com'
)

"""# **Study Area**"""

forest = (
    ee.Image("UMD/hansen/global_forest_change_2025_v1_13")
    .select('loss', 'lossyear')
)

loss_area = forest.select('loss').eq(1).And(
    forest.select('lossyear').eq(15)
)

import geemap

map = geemap.Map(basemap = 'SATELLITE')
map.addLayer(loss_area,{},'loss_area')
map

roi = map.draw_last_feature.geometry()
roi

"""# **MODIS NDVI Image Collection**"""

modis = (
    ee.ImageCollection("MODIS/061/MOD13Q1")
    .filterDate('2000','2026')
    .select('NDVI')
)

modis

"""# **to Xarray**"""

from xee import helpers
from shapely.geometry import shape
import xarray as xr

grid_params = helpers.fit_geometry(
    geometry = shape(roi.getInfo()),
    grid_crs = 'EPSG:3857',
    grid_scale = (250, -250)
)

ds = xr.open_dataset(
    modis,
    engine = 'ee',
    **grid_params
)

ds = ds.sortby('time') * 0.0001

"""# **NDVI Time Series**"""

ds_mean = ds.mean(dim = ['x', 'y']).to_dataframe()

ds_mean.plot()

"""# **Trend Analysis**"""

from statsmodels.tsa.seasonal import STL

stl_model = STL(ds_mean, period = 24)
stl_result = stl_model.fit()

ndvi_trend = stl_result.trend

ndvi_trend.plot()

