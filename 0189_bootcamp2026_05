import ee

import geemap

ee.Authenticate()
ee.Initialize(
    project = 'ee-amirhosseinahrari',
    opt_url = 'https://earthengine-highvolume.googleapis.com'
)

map = geemap.Map(basemap = 'SATELLITE')
map

roi = map.draw_last_feature.geometry()

sen2 = (
    ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED")
    .filterDate('2019','2020')
    .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE',5))
    .filterBounds(roi)
    .select('B[2-4]','B8')
    .median().multiply(0.0001)
)

sen2

import xarray as xr

ds = xr.open_dataset(
    sen2,
    engine = 'ee',
    crs = 'EPSG:3857',
    geometry = roi,
    scale = 30
)

ds= ds.squeeze('time').drop_vars('time') * 1

nir = ds.B8
red = ds.B4
ndvi = (nir - red) / (nir + red)

!pip install hvplot
import hvplot.xarray

import numpy as np

condition1 = xr.where(ndvi < 0, 1, np.nan)
condition2 = xr.where(ndvi > 0.2, 2, condition1)
condition3 = xr.where((ndvi >= 0)&(ndvi <= 0.2) , 3, condition2)

condition3.plot(
    x = 'X', y = 'Y'
)
