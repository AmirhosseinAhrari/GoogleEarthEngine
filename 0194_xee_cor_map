import ee

ee.Authenticate()
ee.Initialize(
    project = 'ee-amirhosseinahrari',
    opt_url = 'https://earthengine-highvolume.googleapis.com'
)

import geemap

map = geemap.Map(basemap = 'SATELLITE')
map

roi = map.draw_last_feature.geometry()
roi

time_start = ee.Date('2017')
time_end = ee.Date('2022')

smap = (
    ee.ImageCollection("NASA/SMAP/SPL3SMP_E/005")
    .filterDate(time_start, time_end)
    .select('soil_moisture_am')
)

pr = (
    ee.ImageCollection("NASA/GPM_L3/IMERG_MONTHLY_V07")
    .filterDate(time_start, time_end)
    .select('precipitation')
)

pr

import xarray as xr

ds_pr = xr.open_dataset(
    pr,
    engine = 'ee',
    geometry = roi,
    crs = 'EPSG:4326',
    scale = 0.1
)

ds_pr = ds_pr.sortby('time') * 1

ds_pr

ds_smap = xr.open_dataset(
    smap,
    engine = 'ee',
    geometry = roi,
    crs = 'EPSG:4326',
    scale = 0.1
)

ds_smap = ds_smap.sortby('time') * 1

smap_monthly = ds_smap.resample(time = 'MS').mean('time')

smap_monthly

sm_aligned, pr_aligned = xr.align(
    smap_monthly['soil_moisture_am'],
    ds_pr['precipitation'],
    join = 'inner',
    exclude = ['lat','lon']
)

pr_regridded = pr_aligned.interp(
    lat = sm_aligned.lat,
    lon = sm_aligned.lon,
    method = 'nearest'
)

pr_regridded

cor_map = xr.corr(sm_aligned,pr_regridded, dim = 'time' )

cor_map.plot(
    x = 'lon', y = 'lat', robust = True, cmap = 'jet'
)

from scipy import stats

def spearman(x, y):
  c_map, p_map = stats.spearmanr(x, y)
  return c_map, p_map

c_map, p_map = xr.apply_ufunc(
    spearman,
    sm_aligned,
    pr_regridded,
    input_core_dims = [['time'], ['time']],
    output_core_dims = [[],[]],
    vectorize= True,
    dask = 'parallelized',
    output_dtypes = [float, float]
)

import numpy as np

cmap_val = xr.where(p_map <= 0.05, c_map, np.nan)

cmap_val.plot(
    x = 'lon', y = 'lat', robust = True, cmap = 'jet'
)
