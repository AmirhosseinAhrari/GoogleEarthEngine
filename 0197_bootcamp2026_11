import ee

ee.Authenticate()
ee.Initialize(
    project = 'ee-amirhosseinahrari',
    opt_url = 'https://earthengine-highvolume.googleapis.com'
)

import geemap

map = geemap.Map(basemap = 'SATELLITE')
map

roi = map.draw_last_feature.geometry()
roi

label = (
    ee.ImageCollection("ESA/WorldCover/v200")
    .filterBounds(roi)
    .first()
)


def features(img):
  fmask = img.select('Fmask')
  bit0 = fmask.bitwiseAnd(1 << 0).neq(0)
  bit1 = fmask.bitwiseAnd(1 << 1).neq(0)
  bit3 = fmask.bitwiseAnd(1 << 3).neq(0)
  mask = bit0.Or(bit1).Or(bit3)
  ms = img.select('B[2-7]')
  tir = img.select('B10')
  ndvi = ms.normalizedDifference(['B5','B4']).rename('ndvi')
  ndwi = ms.normalizedDifference(['B3', 'B5']).rename('ndwi')
  stack = ee.Image.cat([ms, tir, ndvi, ndwi])
  return stack.updateMask(mask.Not())

landsat = (
    ee.ImageCollection("NASA/HLS/HLSL30/v002")
    .filterDate('2025','2026')
    .filterBounds(roi)
    .filter(ee.Filter.lt('CLOUD_COVERAGE', 40))
    .map(features)
)

ms_median = landsat.select('B.*').median()
index_median = landsat.select('n.*').median()
index_std = landsat.select('n.*').reduce(ee.Reducer.stdDev())

dataset = ee.Image.cat([ms_median, index_median, index_std])

dataset

import xarray as xr

label_ds = xr.open_dataset(
    label,
    engine = 'ee',
    crs = 'EPSG:3857',
    geometry = roi,
    scale = 100
)

label_ds =  label_ds.squeeze('time').drop_vars('time')

landsat_ds = xr.open_dataset(
    dataset,
    engine = 'ee',
    crs = 'EPSG:3857',
    geometry = roi,
    scale = 100
)

landsat_ds = landsat_ds.squeeze('time').drop_vars('time') * 1

label_ds_int = label_ds.interp(
    X = landsat_ds.X,
    Y = landsat_ds.Y,
    method = 'nearest'
)

landsat_aligned, label_aligned = xr.align(
    landsat_ds,
    label_ds_int
)

label_aligned

landsat_aligned

ds = xr.merge([landsat_aligned, label_aligned])

ds

df = ds.to_dataframe().dropna()

df

x = df.drop('Map', axis = 1)
y = df['Map']

from sklearn.model_selection import train_test_split

x_train, x_test, y_train, y_test = train_test_split(
    x, y, test_size = 0.2, random_state = 42
)

from sklearn.ensemble import RandomForestClassifier

model = RandomForestClassifier(n_estimators = 100,
                               random_state = 42)
model.fit(x_train, y_train)

y_pred = model.predict(x_test)

from sklearn.metrics import classification_report

print(classification_report(y_test, y_pred))

df['class_val'] = model.predict(x)

final = df.to_xarray().sortby('Y','X')

final['class_val'].plot(
    x = 'X', y = 'Y', cmap = 'jet'
)
