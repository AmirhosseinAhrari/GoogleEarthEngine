import ee

ee.Authenticate()
ee.Initialize(
    project = 'ee-amirhosseinahrari',
    opt_url = 'https://earthengine-highvolume.googleapis.com'
)

import geemap

map = geemap.Map()
map

roi = map.draw_last_feature.geometry()
roi

temp = (
    ee.ImageCollection("NASA/VIIRS/002/VNP21A1D")
    .filterDate('2020','2021')
    .select('LST_1KM')
)

temp

ndvi = (
     ee.ImageCollection("NASA/VIIRS/002/VNP13A1")
     .filterDate('2020','2021')
     .select('NDVI')
 )

ndvi

import xarray as xr

ds_temp = xr.open_dataset(
    temp,
    engine = 'ee',
    crs = 'EPSG:4326',
    geometry = roi,
    scale = 0.01
)

ds_temp

ds_ndvi = xr.open_dataset(
    ndvi,
    engine = 'ee',
    crs = 'EPSG:4326',
    geometry = roi,
    scale = 0.005
)

ds_ndvi

ds_temp = ds_temp.sortby('time') * 1

ds_ndvi = ds_ndvi.sortby('time') * 1

ds_temp_monthly = ds_temp.resample(time  = 'M').mean('time')
ds_ndvi_monthly = ds_ndvi.resample(time = 'M').median('time')

ds_temp_monthly

ds_ndvi_monthly

ds_ndvi_like_temp = ds_ndvi_monthly.interp_like(ds_temp_monthly)

ds_temp_monthly

ds_ndvi_like_temp

merge = xr.merge([ds_temp_monthly, ds_ndvi_like_temp])

merge

!pip install netCDF4
import netCDF4

merge.to_netcdf('merged_ds.nc')

merge.LST_1KM.plot(
    x = 'lon', y = 'lat', col = 'time', col_wrap = 6, cmap = 'RdBu_r', robust = True
)

merge.NDVI.plot(
    x = 'lon', y = 'lat', col = 'time', col_wrap = 6, robust = True, cmap = 'RdYlGn'
)
